rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Allow read/write if the userId is long enough to be an unguessable token
      allow read, write: if userId.size() > 20;
      
      match /history/{historyId} {
        allow read, write: if userId.size() > 20;
      }
      
      match /sessions/{sessionId} {
        allow read, write: if userId.size() > 20;
      }
    }
  }
}
